# ─── Deployer wallet ──────────────────────────────────────────────────────────
# Your private key (without 0x prefix). NEVER commit a real key.
PRIVATE_KEY=your_private_key_here

# ─── RPC ──────────────────────────────────────────────────────────────────────
# Monad testnet public RPC (default — no change needed unless you have a private node)
MONAD_TESTNET_RPC=https://testnet-rpc.monad.xyz

# ─── Block explorer verification (optional) ───────────────────────────────────
MONAD_EXPLORER_API_KEY=no-api-key

# ─── Gas reporting (optional) ─────────────────────────────────────────────────
REPORT_GAS=false
