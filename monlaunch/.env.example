# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string (Vercel Postgres, Neon, Supabase, Railway, etc.)
DATABASE_URL=postgresql://user:password@host:5432/monlaunch

# ── NextAuth ──────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-here
NEXTAUTH_URL=http://localhost:3000

# ── Pinata (IPFS for token images & metadata) ─────────────────────────────────
# Get keys at https://pinata.cloud
PINATA_JWT=your-pinata-jwt-here
NEXT_PUBLIC_PINATA_GATEWAY=https://gateway.pinata.cloud

# ── WalletConnect ─────────────────────────────────────────────────────────────
# Get a free Project ID at https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your-project-id-here

# ── Contract (auto-populated from deployment) ──────────────────────────────────
NEXT_PUBLIC_FACTORY_ADDRESS=0xEA2530C202BcDc14bF57277137A3802e19705D7e
NEXT_PUBLIC_CHAIN_ID=10143
NEXT_PUBLIC_CHAIN_NAME=Monad Testnet
NEXT_PUBLIC_RPC_URL=https://testnet-rpc.monad.xyz
NEXT_PUBLIC_EXPLORER_URL=https://testnet.monadexplorer.com
